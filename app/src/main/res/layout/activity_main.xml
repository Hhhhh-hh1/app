<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background"
    android:overScrollMode="never"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <!-- 顶部 Header 栏 -->
        <RelativeLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:layout_marginBottom="16dp">

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:layout_alignParentStart="true"
                android:layout_toStartOf="@+id/btnTestGallery">

                <TextView
                    android:id="@+id/titleText"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="画质分析评估中心"
                    android:textColor="@color/text_main"
                    android:textSize="22sp"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/subtitleText"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="4dp"
                    android:text="基于传统 CV 算子的图像清晰度、曝光与噪点分析"
                    android:textColor="@color/text_sub"
                    android:textSize="13sp" />
            </LinearLayout>

        </RelativeLayout>

        <!-- 图像展示/上传占位区域 -->
        <FrameLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content">

            <!-- 未选择图片时的占位卡片 -->
            <LinearLayout
                android:id="@+id/selectPlaceholder"
                android:layout_width="match_parent"
                android:layout_height="220dp"
                android:background="@drawable/upload_border_dashed"
                android:clickable="true"
                android:focusable="true"
                android:gravity="center"
                android:orientation="vertical"
                android:padding="20dp">

                <ImageView
                    android:layout_width="48dp"
                    android:layout_height="48dp"
                    android:src="@drawable/ic_upload" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="12dp"
                    android:text="点击此处导入图像"
                    android:textColor="@color/text_main"
                    android:textSize="16sp"
                    android:textStyle="bold" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="6dp"
                    android:text="支持 JPEG, PNG, WebP, HEIC, AVIF, BMP, GIF"
                    android:textColor="@color/text_sub"
                    android:textSize="12sp" />
            </LinearLayout>

            <!-- 已选择图片时的预览区域 -->
            <ImageView
                android:id="@+id/previewImage"
                android:layout_width="match_parent"
                android:layout_height="220dp"
                android:background="@drawable/card_background"
                android:contentDescription="图片预览"
                android:padding="6dp"
                android:scaleType="centerInside"
                android:visibility="gone" />
        </FrameLayout>

        <!-- 按钮与状态提示 -->
        <androidx.appcompat.widget.AppCompatButton
            android:id="@+id/selectButton"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:layout_marginTop="16dp"
            android:background="@drawable/button_gradient_bg"
            android:text="重新选择图片"
            android:textAllCaps="false"
            android:textColor="#FFFFFF"
            android:textSize="15sp"
            android:textStyle="bold"
            android:visibility="gone" />

        <TextView
            android:id="@+id/statusText"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:gravity="center"
            android:text="请导入图片以启动传统画质指标评估。"
            android:textColor="@color/text_sub"
            android:textSize="13sp" />

        <androidx.appcompat.widget.AppCompatButton
            android:id="@+id/btnTestGallery"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:layout_marginTop="24dp"
            android:background="@drawable/card_background"
            android:text="进入动态对比测试图集"
            android:textAllCaps="false"
            android:textColor="@color/accent"
            android:textSize="15sp"
            android:textStyle="bold" />

        <!-- Tab 切换栏 -->
        <LinearLayout
            android:id="@+id/tabLayout"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:layout_marginBottom="8dp"
            android:background="@drawable/tab_layout_bg"
            android:orientation="horizontal"
            android:padding="4dp"
            android:visibility="gone">

            <TextView
                android:id="@+id/tabOverview"
                android:layout_width="0dp"
                android:layout_height="36dp"
                android:layout_weight="1"
                android:gravity="center"
                android:text="基本结果"
                android:textColor="@color/text_main"
                android:textSize="13sp"
                android:textStyle="bold"
                android:background="@drawable/tab_item_selected_bg"
                android:clickable="true"
                android:focusable="true" />

            <TextView
                android:id="@+id/tabDetails"
                android:layout_width="0dp"
                android:layout_height="36dp"
                android:layout_weight="1"
                android:gravity="center"
                android:text="维度指标"
                android:textColor="@color/text_sub"
                android:textSize="13sp"
                android:background="@android:color/transparent"
                android:clickable="true"
                android:focusable="true" />
        </LinearLayout>

        <!-- 第一页：基本结果容器 -->
        <LinearLayout
            android:id="@+id/overviewLayout"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:visibility="gone">

            <!-- 综合评分与基本信息（结果面板） -->
            <LinearLayout
                android:id="@+id/resultPanel"
                android:layout_width="match_parent"
                android:layout_height="130dp"
                android:layout_marginTop="12dp"
                android:orientation="horizontal"
                android:visibility="gone">

                <!-- 环形得分仪表盘 -->
                <com.example.imagequality.CircularScoreView
                    android:id="@+id/scoreView"
                    android:layout_width="130dp"
                    android:layout_height="130dp"
                    android:layout_gravity="center_vertical" />

                <!-- 文件基本规格信息 -->
                <TextView
                    android:id="@+id/fileInfoText"
                    android:layout_width="0dp"
                    android:layout_height="match_parent"
                    android:layout_marginStart="12dp"
                    android:layout_weight="1"
                    android:background="@drawable/card_background"
                    android:gravity="center_vertical"
                    android:lineSpacingExtra="3dp"
                    android:padding="12dp"
                    android:text="图片信息..."
                    android:textColor="@color/text_main"
                    android:textSize="12sp" />
            </LinearLayout>

            <!-- 评估报告摘要 -->
            <LinearLayout
                android:id="@+id/summaryCard"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="14dp"
                android:background="@drawable/card_background"
                android:orientation="vertical"
                android:padding="14dp"
                android:visibility="gone">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="评估报告结论"
                    android:textColor="@color/accent"
                    android:textSize="13sp"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/summaryText"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="6dp"
                    android:lineSpacingExtra="2dp"
                    android:text="评价说明将在分析后显示。"
                    android:textColor="@color/text_main"
                    android:textSize="13sp" />
            </LinearLayout>
        </LinearLayout>

        <!-- 第二页：维度指标与详情容器 -->
        <LinearLayout
            android:id="@+id/detailsLayout"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:visibility="gone">

            <!-- 维度指标卡片列表标题 -->
            <TextView
                android:id="@+id/detailsTitleText"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:layout_marginBottom="8dp"
                android:text="子维度指标详情"
                android:textColor="@color/text_main"
                android:textSize="15sp"
                android:textStyle="bold"
                android:visibility="gone" />

            <!-- 维度指标动态生成容器 -->
            <LinearLayout
                android:id="@+id/metricsContainer"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical" />

            <!-- 底部折叠说明卡片 -->
            <LinearLayout
                android:id="@+id/tipsCard"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="20dp"
                android:layout_marginBottom="12dp"
                android:background="@drawable/card_background"
                android:orientation="vertical"
                android:padding="12dp">

                <!-- 折叠 Header -->
                <LinearLayout
                    android:id="@+id/tipsHeader"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:clickable="true"
                    android:focusable="true"
                    android:gravity="center_vertical"
                    android:orientation="horizontal">

                    <ImageView
                        android:layout_width="16dp"
                        android:layout_height="16dp"
                        android:src="@drawable/ic_tips"
                        android:contentDescription="提示图标" />

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="8dp"
                        android:layout_weight="1"
                        android:text="算法说明与格式说明"
                        android:textColor="@color/text_main"
                        android:textSize="13sp"
                        android:textStyle="bold" />

                    <TextView
                        android:id="@+id/tipsToggleArrow"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="展开"
                        android:textColor="@color/primary"
                        android:textSize="12sp" />
                </LinearLayout>

                <!-- 折叠 Content -->
                <LinearLayout
                    android:id="@+id/tipsContent"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:orientation="vertical"
                    android:visibility="gone">

                    <TextView
                        android:id="@+id/formatText"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="【格式支持】JPEG / PNG / WebP 完美支持；HEIC / AVIF / BMP / GIF 首帧解析取决于当前真机设备的解码能力。"
                        android:textColor="@color/text_sub"
                        android:textSize="12sp"
                        android:lineSpacingExtra="2dp" />

                    <View
                        android:layout_width="match_parent"
                        android:layout_height="0.5dp"
                        android:layout_marginTop="8dp"
                        android:layout_marginBottom="8dp"
                        android:background="@color/border" />

                    <TextView
                        android:id="@+id/limitationText"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="【算法限制】采用灰度 Laplacian 方差算子、邻域均值差、白平衡漂移等传统 CV 分析，非深度学习，纯色图或特殊艺术滤镜可能失准。"
                        android:textColor="@color/text_sub"
                        android:textSize="12sp"
                        android:lineSpacingExtra="2dp" />
                </LinearLayout>
            </LinearLayout>
        </LinearLayout>
    </LinearLayout>
</ScrollView>
